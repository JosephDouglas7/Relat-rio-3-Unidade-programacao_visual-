    Product(
      id: 'p5',
      name: 'Smartphone 2Y',
      description: 'Tela 6.0", 256GB, câmera 80MP',
      price: 2000.00,
      images: [
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+1',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+2',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+3',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+4',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+5',
      ],
    ),
  ];

  final List<Product> cart = [];

  void addToCart(Product p) {
    setState(() => cart.add(p));

    final ctx = navigatorKey.currentContext;
    if (ctx != null) {
      ScaffoldMessenger.of(ctx).showSnackBar(
        SnackBar(content: Text('${p.name} adicionado ao carrinho')),
      );
    } else {
      // Fallback para desenvolvimento
      // ignore: avoid_print
      print(
          '${p.name} adicionado ao carrinho (contexto não disponível para SnackBar)');
    }
  }

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Smartpod',
      navigatorKey: navigatorKey,
      theme: ThemeData(primarySwatch: Colors.blue),
      routes: {
        '/': (_) => const HomePage(),
        '/products': (_) =>
            ProductsPage(products: products, onAddToCart: addToCart),
        '/product': (_) => const ProductDetailPage(),
        '/cart': (_) => CartPage(cart: cart),
        '/tasks': (_) => const TasksPage(),
        '/task_form': (_) => const TaskFormPage(),
      },
      initialRoute: '/',
    );
  }
}
