      description: 'Tela 6.0", 256GB, câmera 70MP',
      price: 1900.00,
      images: [
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+1',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+2',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+3',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+4',
        'https://via.placeholder.com/800x800.png?text=Beta+Pro+5',
      ],
